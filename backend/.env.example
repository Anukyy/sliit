# Copy to .env locally. On Railway, set variables in the dashboard (do not commit .env).

PORT=5000
# Railway injects PORT automatically — leave unset on Railway unless debugging.

MONGODB_URI=mongodb+srv://anuki:1234@cluster0.0euc6qz.mongodb.net/?appName=Cluster0
# Production: use Atlas SRV or Railway MongoDB plugin URI.

JWT_SECRET=change-me-in-production
# Production: use a long random secret.

# Optional: public hostname for logs (mobile apps should use EXPO_PUBLIC_API_URL → https://YOUR_APP.up.railway.app/api)
PUBLIC_HOST=https://sliit-production.up.railway.app/api